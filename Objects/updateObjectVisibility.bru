meta {
  name: updateObjectVisibility
  type: http
  seq: 9
}

put {
  url: {{PROTOCOL}}://{{HOST}}:{{PORT}}/api/v1/storage/objects/visibility/:id/:state
  body: none
  auth: inherit
}

params:path {
  id: [file_name]
  state: [private, public, shared]
}

settings {
  encodeUrl: true
  timeout: 0
}
