meta {
  name: updateObject
  type: http
  seq: 5
}

put {
  url: {{PROTOCOL}}://{{HOST}}:{{PORT}}/storage/objects/:id
  body: multipartForm
  auth: inherit
}

params:path {
  id: [file_name]
}

body:multipart-form {
  file: @file(/home/ppontet/Downloads/arch.md)
  ~files[]: 
}

settings {
  encodeUrl: true
  timeout: 0
}
