meta {
  name: Signup
  type: http
  seq: 1
}

post {
  url: {{PROTOCOL}}://{{HOST}}:{{PORT}}/api/v1/auth/signup
  body: json
  auth: inherit
}

body:json {
  {
    "fullName": "test",
    "email": "test@test.test",
    "password": "password",
    "passwordConfirmation": "password"
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
